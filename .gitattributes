# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Jupyter notebooks
*.ipynb text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# Documentation
*.rst text eol=lf
*.txt text eol=lf

# YAML/Config
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Data files
*.csv text eol=lf

# Binary files
*.pkl binary
*.pickle binary
*.joblib binary
*.pth binary
*.pt binary
*.h5 binary
*.model binary
*.pb binary

# Images (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary

# Compressed (binary)
*.zip binary
*.tar binary
*.tar.gz binary
*.rar binary
*.7z binary

# VLSI files
*.gds binary
*.gdsii binary
*.db binary
*.view binary
*.lib binary
